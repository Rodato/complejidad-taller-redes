# Copia este archivo a `.streamlit/secrets.toml` y rellénalo.
# NO COMMITAR el secrets.toml real (está en .gitignore).
#
# Pasos para obtener el bloque [gcp_service_account]:
# 1. Ir a https://console.cloud.google.com → crear proyecto (o usar uno existente)
# 2. Habilitar la "Google Sheets API" para ese proyecto
# 3. IAM & Admin → Service Accounts → Create Service Account
# 4. En el service account → Keys → Add Key → Create new key → JSON
# 5. Pegar los campos del JSON descargado abajo (cuidado con las comillas y los \n del private_key)
# 6. Crear una Google Sheet, compartirla con el `client_email` del service account con permiso de Editor
# 7. Pegar la URL de la hoja en [sheets].url
#
# En Streamlit Cloud: este archivo se pega tal cual en "Settings → Secrets" del app.

[gcp_service_account]
type = "service_account"
project_id = "tu-proyecto-gcp"
private_key_id = "abc123..."
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
client_email = "detective-redes@tu-proyecto-gcp.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/detective-redes%40tu-proyecto-gcp.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

[sheets]
url = "https://docs.google.com/spreadsheets/d/AQUI_EL_ID_DE_LA_HOJA/edit"
worksheet = "respuestas"
